$(ARCHDIR)/fs/iso9660.o \
$(ARCHDIR)/xz/xz.o \
$(ARCHDIR)/xz/xz_crc32.o \
$(ARCHDIR)/xz/xz_dec_lzma2.o \
$(ARCHDIR)/xz/xz_dec_stream.o \
